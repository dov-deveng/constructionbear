{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/app",      "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/", "permanent": false, "destination": "/app" }
  ]
}
