# ConstructionBear.AI — Server Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Google OAuth ─────────────────────────────
# Get credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: Stripe Payments ──────────────────────────
# Get keys at dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Optional: Email (verification + password reset) ───
# Works with any SMTP. For Gmail, use an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# ── Optional: URLs ─────────────────────────────────────
CLIENT_URL=http://localhost:5173
PORT=3457

# ── Optional: Database path ───────────────────────────
# Defaults to server/data/constructionbear.db
# DB_PATH=/custom/path/to/db.sqlite

# ── Admin account ─────────────────────────────────────
# This email gets is_admin=1 on every server start.
# Admin accounts bypass the Stripe paywall entirely.
ADMIN_EMAIL=you@yourdomain.com
# Comma-separated emails that bypass the paywall (for demos/testing). Not admin access.
TEST_EMAILS=test@example.com,demo@example.com
